{
  "name": "voto-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "check": "next typegen && tsc --noEmit",
    "lint": "prettier --check . && eslint --max-warnings=0 . && i18n-check -s en -l messages -f next-intl -u src",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "shadcn:update": "node scripts.ts update-shadcn-components"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
